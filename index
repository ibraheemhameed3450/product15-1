<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Luxury Picks | Premium Amazon Finds</title>
  <style>
    :root {
      --white: #ffffff;
      --gray: #f5f5f7;
      --gray-2: #e9e9ee;
      --dark: #0f1115;
      --dark-2: #1d1d1f;
      --text-soft: #6e6e73;
      --accent: #0a84ff;
      --accent-2: #6ea8ff;
      --gold: #d4af37;
      --glass: rgba(255, 255, 255, 0.58);
      --glass-border: rgba(255, 255, 255, 0.55);
      --shadow-sm: 0 12px 30px rgba(15, 17, 21, 0.08);
      --shadow-md: 0 20px 50px rgba(15, 17, 21, 0.14);
      --shadow-lg: 0 30px 80px rgba(15, 17, 21, 0.18);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --max-width: 1240px;
    }
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text",
    "Inter", "Segoe UI", sans-serif;
  color: var(--dark-2);
  background:
    radial-gradient(circle at top left, rgba(212, 175, 55, 0.08), transparent 26%),
    radial-gradient(circle at top right, rgba(10, 132, 255, 0.10), transparent 30%),
    linear-gradient(180deg, #fcfcfd 0%, #f5f5f7 45%, #eeeeF1 100%);
  overflow-x: hidden;
  line-height: 1.5;
}

img {
  display: block;
  max-width: 100%;
}

a {
  text-decoration: none;
  color: inherit;
}

.container {
  width: min(var(--max-width), calc(100% - 40px));
  margin-inline: auto;
}

.section {
  padding: 88px 0;
  position: relative;
}

.section-title {
  font-size: clamp(2rem, 4vw, 3.25rem);
  line-height: 1.05;
  letter-spacing: -0.04em;
  text-align: center;
  margin-bottom: 14px;
  font-weight: 700;
}

.section-subtitle {
  text-align: center;
  color: var(--text-soft);
  font-size: 1.05rem;
  max-width: 760px;
  margin: 0 auto 48px;
}

.glass {
  background: var(--glass);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border: 1px solid var(--glass-border);
  box-shadow: var(--shadow-sm);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  border: 0;
  cursor: pointer;
  border-radius: 999px;
  font-weight: 600;
  transition: transform 0.35s ease, box-shadow 0.35s ease, background 0.35s ease, color 0.35s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--dark), #2a2d33);
  color: var(--white);
  padding: 15px 28px;
  box-shadow: 0 16px 35px rgba(15, 17, 21, 0.22);
}

.btn-primary:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 22px 44px rgba(15, 17, 21, 0.26);
}

.btn-amazon {
  width: 100%;
  padding: 13px 18px;
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
  color: var(--white);
  font-size: 0.98rem;
  box-shadow: 0 12px 24px rgba(10, 132, 255, 0.22);
}

.btn-amazon:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 30px rgba(10, 132, 255, 0.28);
}

/* Hero */
.hero {
  min-height: 100svh;
  display: grid;
  align-items: center;
  position: relative;
  overflow: clip;
  padding: 100px 0 60px;
}

.hero::before,
.hero::after {
  content: "";
  position: absolute;
  border-radius: 999px;
  filter: blur(50px);
  z-index: 0;
  opacity: 0.7;
  pointer-events: none;
}

.hero::before {
  width: 340px;
  height: 340px;
  background: rgba(10, 132, 255, 0.15);
  top: 10%;
  right: 8%;
}

.hero::after {
  width: 280px;
  height: 280px;
  background: rgba(212, 175, 55, 0.12);
  bottom: 10%;
  left: 8%;
}

.hero-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 40px;
  align-items: center;
}

.hero-copy h1 {
  font-size: clamp(2.8rem, 7vw, 6rem);
  line-height: 0.95;
  letter-spacing: -0.055em;
  font-weight: 800;
  margin-bottom: 20px;
}

.hero-copy p {
  font-size: 1.12rem;
  color: var(--text-soft);
  max-width: 640px;
  margin-bottom: 28px;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-bottom: 28px;
}

.hero-note {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  color: #5f6368;
  font-size: 0.95rem;
}

.hero-visual {
  position: relative;
  min-height: 580px;
  perspective: 1400px;
}

.floating-panel {
  position: absolute;
  border-radius: 28px;
  overflow: hidden;
  transform-style: preserve-3d;
  transition: transform 0.6s ease;
  box-shadow: var(--shadow-lg);
}

.floating-panel img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.panel-main {
  width: min(100%, 470px);
  height: 520px;
  right: 0;
  top: 20px;
}

.panel-small {
  width: 220px;
  height: 160px;
  left: 10px;
  bottom: 60px;
}

.panel-badge {
  position: absolute;
  top: 30px;
  left: 10px;
  padding: 14px 18px;
  border-radius: 18px;
  width: 220px;
}

.badge-kicker {
  font-size: 0.8rem;
  color: var(--text-soft);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 6px;
}

.badge-title {
  font-size: 1rem;
  font-weight: 700;
}

/* Products */
.products-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px;
}

.product-card {
  position: relative;
  border-radius: var(--radius-xl);
  padding: 18px;
  overflow: hidden;
  transform-style: preserve-3d;
  transition: transform 0.45s ease, box-shadow 0.45s ease, border-color 0.45s ease;
  will-change: transform;
}

.product-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(10, 132, 255, 0.10), transparent 28%),
    radial-gradient(circle at bottom left, rgba(212, 175, 55, 0.10), transparent 30%);
  pointer-events: none;
}

.product-card:hover {
  transform: translateY(-10px) rotateX(4deg) rotateY(-4deg);
  box-shadow: var(--shadow-lg);
}

.product-media {
  aspect-ratio: 1 / 0.78;
  border-radius: 20px;
  overflow: hidden;
  background: linear-gradient(135deg, #f7f8fa, #e8ebf2);
  margin-bottom: 18px;
}

.product-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.55s ease;
}

.product-card:hover .product-media img {
  transform: scale(1.05);
}

.product-title {
  font-size: 1.22rem;
  line-height: 1.15;
  letter-spacing: -0.03em;
  margin-bottom: 8px;
  font-weight: 700;
}

.product-desc {
  color: var(--text-soft);
  font-size: 0.96rem;
  margin-bottom: 14px;
}

.features {
  list-style: none;
  display: grid;
  gap: 8px;
  margin-bottom: 16px;
}

.features li {
  font-size: 0.92rem;
  color: #494c52;
  padding-left: 18px;
  position: relative;
}

.features li::before {
  content: "•";
  position: absolute;
  left: 0;
  color: var(--accent);
  font-weight: 700;
}

.card-bottom {
  display: grid;
  gap: 14px;
  margin-top: auto;
}

.rating {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.95rem;
  color: #5f6368;
}

.stars {
  color: var(--gold);
  letter-spacing: 0.08em;
  font-size: 1rem;
}

/* Top Pick */
.best-pick {
  display: grid;
  grid-template-columns: 0.95fr 1.05fr;
  gap: 34px;
  align-items: center;
  padding: 28px;
  border-radius: 34px;
  position: relative;
  overflow: hidden;
}

.best-pick::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(212,175,55,0.12), transparent 28%),
    radial-gradient(circle at bottom right, rgba(10,132,255,0.10), transparent 32%);
  pointer-events: none;
}

.best-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #e1ba49, #cfa32a);
  color: white;
  padding: 8px 14px;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 700;
  margin-bottom: 16px;
  box-shadow: 0 12px 26px rgba(212, 175, 55, 0.25);
}

.best-media {
  border-radius: 28px;
  overflow: hidden;
  min-height: 430px;
  box-shadow: var(--shadow-md);
}

.best-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.best-content {
  position: relative;
  z-index: 1;
}

.best-content h2 {
  font-size: clamp(2rem, 4vw, 3.3rem);
  line-height: 1.02;
  letter-spacing: -0.045em;
  margin-bottom: 14px;
}

.best-content p {
  color: var(--text-soft);
  font-size: 1.04rem;
  margin-bottom: 22px;
  max-width: 640px;
}

/* Why Choose */
.why-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px;
}

.why-card {
  border-radius: 26px;
  padding: 26px;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}

.why-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-md);
}

.why-icon {
  width: 58px;
  height: 58px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  margin-bottom: 16px;
  font-size: 1.5rem;
  background: linear-gradient(135deg, rgba(10,132,255,0.12), rgba(212,175,55,0.12));
}

.why-card h3 {
  font-size: 1.15rem;
  margin-bottom: 8px;
}

.why-card p {
  color: var(--text-soft);
  font-size: 0.96rem;
}

/* Pinterest Gallery */
.gallery-grid {
  columns: 4 220px;
  column-gap: 18px;
}

.gallery-item {
  break-inside: avoid;
  margin-bottom: 18px;
  border-radius: 22px;
  overflow: hidden;
  position: relative;
  box-shadow: var(--shadow-sm);
  transition: transform 0.45s ease, box-shadow 0.45s ease;
}

.gallery-item:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-md);
}

.gallery-item img {
  width: 100%;
  height: auto;
  display: block;
}

/* Disclosure */
.disclosure {
  text-align: center;
  color: #676b72;
  font-size: 0.95rem;
  margin-top: 14px;
}

/* Footer */
footer {
  margin-top: 36px;
  padding: 40px 0 60px;
  border-top: 1px solid rgba(29, 29, 31, 0.08);
}

.footer-wrap {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20px;
  align-items: center;
}

.footer-brand {
  font-size: 1rem;
  color: #4f5358;
}

.footer-links {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.footer-links a {
  color: #4f5358;
  transition: color 0.3s ease;
}

.footer-links a:hover {
  color: var(--dark);
}

/* Animations */
.fade-up {
  opacity: 0;
  transform: translateY(26px);
  transition: opacity 0.9s ease, transform 0.9s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

.delay-1 { transition-delay: 0.08s; }
.delay-2 { transition-delay: 0.16s; }
.delay-3 { transition-delay: 0.24s; }
.delay-4 { transition-delay: 0.32s; }
.delay-5 { transition-delay: 0.40s; }
.delay-6 { transition-delay: 0.48s; }

/* Responsive */
@media (max-width: 1100px) {
  .products-grid,
  .why-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .hero-grid,
  .best-pick {
    grid-template-columns: 1fr;
  }

  .hero-visual {
    min-height: 520px;
  }

  .panel-main {
    position: relative;
    margin-left: auto;
  }
}

@media (max-width: 720px) {
  .section {
    padding: 72px 0;
  }

  .products-grid,
  .why-grid {
    grid-template-columns: 1fr;
  }

  .hero {
    min-height: auto;
    padding-top: 88px;
  }

  .hero-visual {
    min-height: 420px;
  }

  .panel-main {
    height: 360px;
  }

  .panel-small {
    width: 160px;
    height: 120px;
    left: 0;
    bottom: 16px;
  }

  .panel-badge {
    width: 180px;
    top: 12px;
  }

  .best-media {
    min-height: 300px;
  }

  .gallery-grid {
    columns: 2 160px;
  }
}

  </style>
</head>
